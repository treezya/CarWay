<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="480.0" prefWidth="720.0"
            stylesheets="@style.css"
            styleClass="auth-screen"
            xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auto.CarWayScreensAuth$LoginController">

    <center>
        <VBox alignment="CENTER" spacing="16" styleClass="auth-panel">
            <padding>
                <Insets top="36" right="40" bottom="36" left="40"/>
            </padding>
            <Label text="CarWay" styleClass="start-logo"/>
            <Label text="Вход" styleClass="auth-title"/>
            <Label text="Авторизуйтесь для работы с каталогом и заявками"
                   styleClass="auth-subtitle" wrapText="true"/>

            <TextField fx:id="loginField" promptText="E-mail или логин" prefWidth="280" maxWidth="Infinity"/>
            <PasswordField fx:id="passwordField" promptText="Пароль" prefWidth="280" maxWidth="Infinity"/>

            <Button fx:id="loginButton" text="Войти" onAction="#login" prefWidth="280"
                    styleClass="button checkout-primary" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Нет аккаунта?" styleClass="auth-subtitle"/>
                <Hyperlink text="Создать" onAction="#goToSignup"/>
            </HBox>

            <Button text="На главную" onAction="#goBackToStart" styleClass="button nav-outline-light"
                    prefWidth="280" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>
