<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="720.0"
            stylesheets="@style.css"
            styleClass="auth-screen"
            xmlns="http://javafx.com/javafx/17.0.6"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.auto.CarWayScreensAuth$SignupController">

    <center>
        <VBox alignment="CENTER" spacing="14" styleClass="auth-panel">
            <padding>
                <Insets top="32" right="40" bottom="32" left="40"/>
            </padding>
            <Label text="Регистрация" styleClass="auth-title"/>
            <Label text="Создайте аккаунт для доступа к CarWay" styleClass="auth-subtitle"/>

            <TextField fx:id="phoneField" promptText="Телефон" prefWidth="280" maxWidth="Infinity"/>
            <PasswordField fx:id="passwordField" promptText="Пароль" prefWidth="280" maxWidth="Infinity"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Подтверждение пароля"
                           prefWidth="280" maxWidth="Infinity"/>

            <Button text="Создать аккаунт" onAction="#createAccount" prefWidth="280"
                    styleClass="button checkout-primary" maxWidth="Infinity"/>

            <HBox alignment="CENTER" spacing="6">
                <Label text="Уже есть аккаунт?" styleClass="auth-subtitle"/>
                <Hyperlink text="Войти" onAction="#goBackToLogin"/>
            </HBox>

            <Button text="Назад" onAction="#goBackToLogin" styleClass="button nav-outline-light"
                    prefWidth="280" maxWidth="Infinity"/>
        </VBox>
    </center>
</BorderPane>
